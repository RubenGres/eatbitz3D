[node name="Pennyworth" parent="FormigaGloriosa" unique_id=497746263 instance=ExtResource("1_lurwc")]
transform = Transform3D(0.29532456, 0, 0.955397, 0, 1, 0, -0.955397, 0, 0.29532456, 0, 0.52795637, 1)
mesh = ExtResource("10_whepr")
associated_card_texture = ExtResource("14_6vmuk")
ingredient_name = "Pennywort"
ingredient_description = "Pennywort creeps gently across shaded ground, stone walls and rocky crevices, thriving in marginal habitats. It stores water in its round leaves like small green cups. Pennywort knits soil together, preventing erosion and holding water for insects, microbes, and neighboring plants. When you feel rooted in unlikely places, remember that adaptation is your gift. You may not need ideal conditions, only access to a fissure. What small opening could sustain you if you stopped waiting for perfect ground?"

[node name="Dandelion" parent="FormigaGloriosa" unique_id=404686697 instance=ExtResource("1_lurwc")]
transform = Transform3D(1.5649999, 0, 0, 0, 1.2241694, 0.9750047, 0, -0.9750047, 1.2241694, 0, -1.5254183, 1.5203525)
mesh = ExtResource("5_bneni")
associated_card_texture = ExtResource("14_uyet1")
ingredient_name = "Dandelion"
ingredient_description = "Dandelions do not wait for approval. Their taproots drill through compacted ground; their flowers feed early pollinators; their seeds travel without apology. Lawn-owners resent them, yet ecosystems require them. Like the dandelion, your persistence may irritate systems invested in uniformity. But in some cases,
disturbance is not chaos - it is aeration. When will the strength you store below the surface become the force that transforms your environment? "

