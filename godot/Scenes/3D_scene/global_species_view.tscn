[node name="OakAcorn" parent="Node3D2" unique_id=114462614 instance=ExtResource("1_lurwc")]
transform = Transform3D(1.565, 0, 0, 0, 1.565, 0, 0, 0, 1.565, 0, 0, 0)
mesh = ExtResource("2_f221m")
associated_card_texture = ExtResource("5_q0w6e")
ingredient_name = "Acorn"
ingredient_description = "The drought and fire resistant oak teaches that resilience is adaptive, patient, and shared. In the centuries old Montado of the Alentejo, holm oaks rise above grazing lands in  negotiated balance with animals and human care. Here, resilience is not individual permanence but collective continuity. Most acorns never become trees; they nourish birds, insects, fungi, and mammalsinstead. What might change if you stopped trying to become the tree and began nourishing the forest?"

[node name="Node3D3" type="Node3D" parent="." unique_id=274066767]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -3.994214, 0, 3.1845527)

[node name="Mushroom" parent="Node3D3" unique_id=218090739 instance=ExtResource("1_lurwc")]
transform = Transform3D(1.565, 0, 0, 0, 1.565, 0, 0, 0, 1.565, 0, 0, 0)
mesh = ExtResource("4_w6870")
associated_card_texture = ExtResource("7_6vmuk")
ingredient_name = "Chantarelle"
ingredient_description = "Chanterelles rise only where forests are healthy. They weave invisible partnerships with oak and pine roots, exchanging sugars for minerals in quiet reciprocity. You cannot force them; they appear when conditions align. Chanterelle reminds you that some rewards are signs of balance, not effort alone. Visible abundance often reflects invisible reciprocity. Instead of chasing fruiting moments, tend the network. Where in your life is visible abundance revealing invisible cooperation?"

[node name="Marcelo" type="Node3D" parent="." unique_id=1650134456]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 1.504182, 0, 4.3502674)

[node name="Fava" parent="Marcelo" unique_id=991339661 instance=ExtResource("1_lurwc")]
transform = Transform3D(1.314639, 0.7797467, 0.33607224, -0.8489243, 1.1949035, 0.5484141, 0.016645433, -0.6429817, 1.4267173, -0.94328463, 1.7053823, -0.8770398)
mesh = ExtResource("7_q0w6e")
associated_card_texture = ExtResource("7_r4ri1")
ingredient_name = "Fava"
ingredient_description = "Favas may seem ordinary, butunderground they are alchemistscreating soil fertility for all. Theygrow thick and upright, theirroots collaborating with bacteriato fix nitrogen from air into soil. Favas prepare ground for futureharvests, often rotating with grains in traditional Iberian fields. Your work may be preparatory, not final. The fertility you build mightsupport someone else’s flowering.What work would you still do if you never got recognition for it?"

[node name="Elder" parent="Marcelo" unique_id=1556465291 instance=ExtResource("1_lurwc")]
transform = Transform3D(1.565, 0, 0, 0, 1.565, 0, 0, 0, 1.565, 0.7015363, 0.27685487, 0.29099464)
mesh = ExtResource("6_njbcq")
associated_card_texture = ExtResource("9_njbcq")
ingredient_name = "Elderflower"
ingredient_description = "The elder stands at woodland edges as a guardian of thresholds. Across Portugal’s agricultural landscapes, this shrub often marks the boundary between managed fields and wild growth. Its blossoms feed
insects; its berries feed birds; its hollow stems house small creatures within. In European folklore, elder was respected as protective and regenerative. Ecologically, it thrives where disturbance opens space.
You may be called to stand at edges: between systems, communities, or phases. What threshold are you standing upon and hesitating to cross?"

[node name="Fig" parent="Marcelo" unique_id=741763768 instance=ExtResource("1_lurwc")]
transform = Transform3D(2, 0, 0, 0, 1.344837, -1.4803424, 0, 1.4803424, 1.344837, -0.92335033, -1.6976274, -1.4509784)
mesh = ExtResource("9_r4ri1")
associated_card_texture = ExtResource("11_q0w6e")
ingredient_name = "Fig"
ingredient_description = "The fig represents embodied
partnership. It ripens in sweetness
because of a nearly invisible ally:
the fig wasp. The wasp enters
the enclosed flower to pollinate
the fig and lay her eggs, completing
an ancient exchange. In northern
Portugal, fig trees thrive in heat
and poor soils, storing sugars
patiently through long summers,
feeding birds and people alike.
Your abundance, too, rests on
quiet collaborations. What unseen
partnerships are shaping your
becoming?"

