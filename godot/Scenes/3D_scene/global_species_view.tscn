[node name="PurpleBasil" parent="H2Douro" unique_id=1323484318 instance=ExtResource("1_lurwc")]
transform = Transform3D(1.565, 0, 0, 0, 1.565, 0, 0, 0, 1.565, -0.4615698, -0.88218737, 0.69185483)
associated_card_texture = ExtResource("14_whepr")
ingredient_name = "Purple Basil"
ingredient_description = "Purple basil is a bridge between cultivated and wild species. It carries color as protection. Anthocyanins shield it from stress, while aromatic oils deter pests and invite pollinators when it flowers. Long associated with devotion and ritual, purple basil teaches that boundaries and invitations can coexist. What are you attracting, what are you repelling, and are those choices aligned with the ecosystem you wish to belong to?"

