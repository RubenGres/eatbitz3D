[node name="AdditionalInfo" type="Label" parent="Panel/VBoxContainer/ScrollContainer/MarginContainer2/VBoxContainer/MarginContainer2/VBoxContainer" unique_id=170705557]
unique_name_in_owner = true
custom_minimum_size = Vector2(0, 30)
layout_mode = 2
theme_override_font_sizes/font_size = 12
text = "In Roman mythology, strawberries were believed to be the tears of Venus, the goddess of love, and were often associated with love and fertility. During the Middle Ages, they were used to create medicinal remedies, believed to treat ailments ranging from fevers to digestive issues. The first cultivated strawberries in Europe date back to the 18th century, specifically in France, where they were hybridized to create the large, sweet varieties we enjoy today."
autowrap_mode = 3
